# Server
HOST=0.0.0.0
PORT=8095

# Database (Supabase session pooler)
DATABASE_URL=postgresql://postgres.your-ref:password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=

# Encryption (must match frontend)
ENCRYPTION_KEY=your-32-byte-base64-key

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3035

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Zoom OAuth
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# WhatsApp (Gupshup)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# Resend
RESEND_API_KEY=
